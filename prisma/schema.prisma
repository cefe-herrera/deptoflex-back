  id             String                  @id @default(uuid()) @db.Uuid
  propertyFlexId String                  @map("property_flex_id") @db.Uuid
  code           FlexPricingPlanCode
  label          String                  @db.VarChar(120)
  minMonths      Int                     @map("min_months") @db.SmallInt
  maxMonths      Int?                    @map("max_months") @db.SmallInt
  monthlyRent    Decimal                 @map("monthly_rent") @db.Decimal(10, 2)
  currency       String                  @default("ARS") @db.VarChar(3)

  rentIncludesExpenses  Boolean            @default(false) @map("rent_includes_expenses")
  rentIncludesUtilities Boolean            @default(false) @map("rent_includes_utilities")
  includesLinens        Boolean            @default(false) @map("includes_linens")

  depositRule           FlexDepositRule          @default(THIRD_OF_MONTH) @map("deposit_rule")
