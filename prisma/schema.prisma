  professionalProfileId String?       @map("professional_profile_id") @db.Uuid
  clientName            String        @map("client_name") @db.VarChar(200)
  clientEmail           String?       @map("client_email") @db.VarChar(255)
  clientPhone           String?       @map("client_phone") @db.VarChar(30)
