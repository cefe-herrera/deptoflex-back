  sizeM2       Decimal? @map("size_m2") @db.Decimal(8, 2)

  monthlyRate   Decimal  @map("monthly_rate") @db.Decimal(10, 2)
  currency      String   @default("ARS") @db.VarChar(3)
  minMonths     Int      @default(1) @map("min_months") @db.SmallInt
  maxMonths     Int?     @map("max_months") @db.SmallInt
  depositAmount   Decimal? @map("deposit_amount") @db.Decimal(10, 2)
  commissionRate  Decimal? @map("commission_rate") @db.Decimal(5, 2)
