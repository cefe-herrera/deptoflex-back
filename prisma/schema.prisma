  provider     ExternalRequestProvider @default(CLOUDBEDS)
  type         ExternalRequestType
  endpoint     String?                 @db.VarChar(500)
  method       String?                 @db.VarChar(10)
  requestJson  Json                    @map("request_json") @db.JsonB
  responseJson Json?                   @map("response_json") @db.JsonB
  httpStatus   Int?                    @map("http_status")
  durationMs   Int?                    @map("duration_ms")
  success      Boolean                 @default(true)
  errorMessage String?                 @map("error_message") @db.Text
  userId       String?                 @map("user_id") @db.Uuid
  propertyId   String?                 @map("property_id") @db.Uuid
  ipAddress    String?                 @map("ip_address") @db.VarChar(45)
  userAgent    String?                 @map("user_agent") @db.VarChar(500)
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([type, createdAt(sort: Desc)])
  @@index([userId])
  @@index([propertyId])
  @@index([provider, type])
  @@index([createdAt(sort: Desc)])
  @@map("external_requests")
}

model ReservationIntent {
  id           String                  @id @default(uuid()) @db.Uuid
  propertyId   String                  @map("property_id") @db.Uuid
  roomTypeId   String                  @map("room_type_id") @db.VarChar(50)
  rateId       String?                 @map("rate_id") @db.VarChar(50)
  checkin      DateTime                @db.Date
  checkout     DateTime                @db.Date
  adults       Int                     @default(1) @db.SmallInt
  children     Int                     @default(0) @db.SmallInt
  totalAmount  Decimal?                @map("total_amount") @db.Decimal(12, 2)
  currencyCode String                  @map("currency_code") @db.VarChar(3)
  redirectUrl  String                  @map("redirect_url") @db.Text
  status       ReservationIntentStatus @default(PENDING)
  userId       String?                 @map("user_id") @db.Uuid
  professionalProfileId String?         @map("professional_profile_id") @db.Uuid
  ipAddress    String?                 @map("ip_address") @db.VarChar(45)
  userAgent    String?                 @map("user_agent") @db.VarChar(500)
  expiresAt    DateTime                @map("expires_at") @db.Timestamptz
  redirectedAt DateTime?               @map("redirected_at") @db.Timestamptz
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  professionalProfile ProfessionalProfile? @relation(fields: [professionalProfileId], references: [id])
  booking             Booking?

  @@index([propertyId])
  @@index([status, expiresAt])
  @@index([createdAt])
  @@map("reservation_intents")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRACKING DE EMBAJADOR EN CLOUDBEDS
//
// Esta integracion NO usa la API oficial de Cloudbeds. El embajador abre el motor
// publico de Cloudbeds con parametros en la URL (ambassador_id = professionalProfileId,
// session_id) y un script personalizado inyectado en Cloudbeds nos avisa cuando se
// crea la reserva (postMessage + fetch). Esta tabla guarda la sesion liviana previa
// a abrir el motor para poder asociar despues la reserva con el embajador.
// ─────────────────────────────────────────────────────────────────────────────

model AmbassadorBookingSession {
  // id = session_id (UUID) generado en el backend antes de abrir Cloudbeds.
  id                     String                  @id @db.Uuid
  professionalProfileId  String                  @map("professional_profile_id") @db.Uuid
  status                 AmbassadorSessionStatus @default(STARTED)
  mode                   AmbassadorSessionMode   @default(AMBASSADOR)
  // Hash SHA-256 del tracking_token (solo se entrega en claro al crear la sesión).
  trackingTokenHash      String?                 @map("tracking_token_hash") @db.VarChar(64)
  cloudbedsUrl           String                  @map("cloudbeds_url") @db.Text
  propertyId             String?                 @map("property_id") @db.Uuid
  bookingContext         Json?                   @map("booking_context")
  guestReturnUrl         String?                 @map("guest_return_url") @db.Text
  expiresAt              DateTime?               @map("expires_at") @db.Timestamptz
  // Booking local creado al recibir el aviso de reserva (si se pudo asociar).
  bookingId              String?                 @unique @map("booking_id") @db.Uuid
  // booking_id que reporta Cloudbeds (sirve para dedupe junto con el sessionId).
  cloudbedsReservationId String?                 @map("cloudbeds_reservation_id") @db.VarChar(100)
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime                @updatedAt @map("updated_at") @db.Timestamptz

  professionalProfile    ProfessionalProfile     @relation(fields: [professionalProfileId], references: [id])

  @@index([professionalProfileId])
  @@index([trackingTokenHash])
  @@map("ambassador_booking_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENDA (libreta de contactos personal + notas de seguimiento)
// ─────────────────────────────────────────────────────────────────────────────

model AgendaContact {
  id              String    @id @default(uuid()) @db.Uuid
  ownerId         String    @map("owner_id") @db.Uuid
  firstName       String    @map("first_name") @db.VarChar(100)
  lastName        String?   @map("last_name") @db.VarChar(100)
  phone           String?   @db.VarChar(30)
  email           String?   @db.VarChar(255)
  company         String?   @db.VarChar(150)
  avatarColor     String?   @map("avatar_color") @db.VarChar(20)
  lastContactedAt DateTime? @map("last_contacted_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  owner       User         @relation("AgendaOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  agendaNotes AgendaNote[]

  @@index([ownerId, firstName])
  @@index([ownerId, lastContactedAt])
  @@index([deletedAt])
  @@map("agenda_contacts")
}

model AgendaNote {
  id          String   @id @default(uuid()) @db.Uuid
  contactId   String   @map("contact_id") @db.Uuid
  createdById String   @map("created_by_id") @db.Uuid
  body        String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  contact   AgendaContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User          @relation("AgendaNoteAuthor", fields: [createdById], references: [id])

  @@index([contactId, createdAt])
  @@map("agenda_notes")
}
