NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/deptoflex
JWT_SECRET=change-me-to-at-least-32-characters-long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=deptoflex-media
R2_PUBLIC_BASE_URL=https://pub.example.r2.dev

APP_ALLOWED_ORIGINS=http://localhost:3001
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

RESEND_API_KEY=
EMAIL_FROM=Weflex <no-reply@weflex.com.ar>
GOOGLE_CLIENT_ID=

# Mercado Pago — pagos de reserva Flex
# Access token: Credenciales de tu app en https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=

# Secret para validar firma de webhooks (Webhooks > Configurar > Revelar clave secreta)
# NO es la URL del webhook — es la clave secreta generada por Mercado Pago
MERCADOPAGO_WEBHOOK_SECRET=

# Registrar en MP la URL del webhook (debe ser HTTPS en producción):
# ${APP_URL}/api/v1/webhooks/mercadopago
